# wiring-harness dnsmasq entries
#
# Install at /etc/dnsmasq.d/wiring-harness.conf on the WireGuard/dnsmasq server.
# Generated with correct IPs by scripts/setup-mtls.sh — re-run to update.
#
# Replace <wg-server-ip> with the WireGuard server IP from services.local.toml.

address=/<hostname>.home.internal/<wg-server-ip>
address=/<hostname>.home.internal/<wg-server-ip>
