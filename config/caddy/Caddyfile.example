{
	email admin@example.com
}

# Combined Caddyfile — generated by wiring-harness/scripts/setup_caddy.py
# All services share one server TLS cert (SANs cover every registered hostname).
# Each site block enforces mTLS with its own client CA.

# clockwork-web — config.clockwork.internal
https://config.clockwork.internal {
	tls <path-to-server.crt> <path-to-server.key> {
		client_auth {
			mode require_and_verify
			trust_pool file <path-to-ca.crt>
		}
	}

	encode zstd gzip
	reverse_proxy 127.0.0.1:5000

	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "no-referrer"
	}
}

# snowbridge-filebrowser — files.snowbridge.internal
https://files.snowbridge.internal {
	tls <path-to-server.crt> <path-to-server.key> {
		client_auth {
			mode require_and_verify
			trust_pool file <path-to-snowbridge-client-ca.crt>
		}
	}

	encode zstd gzip
	reverse_proxy 127.0.0.1:8080 {
		header_up X-Snowbridge-Auth-User snowbridge
	}

	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "no-referrer"
	}
}
